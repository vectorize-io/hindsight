# CollabMind Dev Observability Stack — Environment Variables
# Copy to .env and adjust for your local setup.

# Host PostgreSQL connection for Langfuse V2
# Default: uses host.docker.internal to reach host machine
LANGFUSE_DATABASE_URL=postgresql://oliververmeulen@host.docker.internal:5432/langfuse
LANGFUSE_NEXTAUTH_SECRET=dev-only-not-secret
LANGFUSE_SALT=dev-salt
LANGFUSE_NEXTAUTH_URL=http://localhost:3002
