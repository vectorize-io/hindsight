{
  "name": "@vectorize-io/hindsight-coding-agents",
  "version": "0.1.0",
  "description": "Reflect-only Hindsight long-term memory for coding agents (harness-pluggable: opencode, \u2026), with a git+chat backfill command.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hindsight-coding-backfill": "dist/backfill.js",
    "hindsight-claude-hook": "dist/claude-hook.js",
    "hindsight-cursor-hook": "dist/cursor-hook.js",
    "hindsight-codex-hook": "dist/codex-hook.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run --exclude '**/*.live.test.ts'",
    "test:live": "HINDSIGHT_LIVE_E2E=1 vitest run src/system.live.test.ts"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.13"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
