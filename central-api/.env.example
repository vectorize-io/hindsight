# CollabMind Central API — example environment. Copy to .env and fill in.
# NEVER commit a real .env. No real client secrets, tokens, or passwords here.

# Runtime
CENTRAL_API_ENV=development
CENTRAL_API_DEBUG=true

# Control-plane database (source of truth).
#   prod:  postgresql+asyncpg://USER:PASSWORD@HOST:5432/collabmind
#   dev:   leave empty to use a local sqlite file (sqlite+aiosqlite:///./central_api_dev.db)
CENTRAL_API_DATABASE_URL=

# Memory engines (internal-only URLs)
CENTRAL_API_MEMLORD_URL=http://memlord.internal:8000
CENTRAL_API_MEMLORD_API_KEY=        # mlk_... — set to enable real MemLord calls
CENTRAL_API_CODERAG_URL=http://coderag.internal:8000
CENTRAL_API_OPENMEMORY_URL=http://openmemory.internal:8080
CENTRAL_API_QDRANT_URL=

# Google Drive connector (READ-ONLY). Obtain from Google Cloud Console.
# Secrets come from the environment ONLY — placeholders shown, never real values.
CENTRAL_API_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
CENTRAL_API_GOOGLE_CLIENT_SECRET=[REDACTED]
CENTRAL_API_GOOGLE_REDIRECT_URI=http://localhost:8000/connectors/google-drive/callback
# Scopes are fixed read-only in code (drive.metadata.readonly, drive.readonly);
# do not add write/delete/admin scopes.
